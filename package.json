{
  "name": "@elgap/ai-curator",
  "version": "0.3.3-beta",
  "description": "AI Curator - Privacy-first dataset curation for LLM fine-tuning",
  "author": "Ivan Pavkovic",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "curator": "./dist/curator.mjs"
  },
  "main": "./dist/curator.mjs",
  "files": [
    ".output/",
    "dist/",
    "bin/",
    "datasets/",
    "scripts/postinstall.js",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "node scripts/postinstall.js || nuxt prepare || true",
    "prepublishOnly": "npm run build && node scripts/bundle-cli.cjs",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "bundle:cli": "node scripts/bundle-cli.cjs",
    "db:reset": "node dist/curator.mjs reset --force",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepare": "husky",
    "clean": "rm -rf .output node_modules/.cache"
  },
  "keywords": [
    "curator",
    "dataset-curation",
    "llm",
    "fine-tuning",
    "dataset",
    "ai",
    "machine-learning",
    "training-data"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elgap/ai-curator.git"
  },
  "bugs": {
    "url": "https://github.com/elgap/ai-curator/issues"
  },
  "homepage": "https://github.com/elgap/ai-curator#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@huggingface/hub": "^2.11.0",
    "@libsql/client": "^0.17.2",
    "@nuxt/ui": "^4.6.1",
    "@pinia/nuxt": "^0.11.3",
    "adm-zip": "^0.5.17",
    "chart.js": "^4.4.9",
    "drizzle-orm": "^0.45.2",
    "kaggle-node": "^1.1.2",
    "libsql": "^0.5.29",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/eslint": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "nuxt": "^4.3.1",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.7",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.8"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "glob": "^13.0.6",
    "defu": "^6.1.5",
    "node-forge": "^1.4.0",
    "picomatch": "^4.0.4",
    "brace-expansion": "^5.0.5",
    "devalue": "^5.6.4",
    "yaml": "^2.8.3",
    "srvx": "^0.11.13",
    "lodash": "^4.17.21"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
