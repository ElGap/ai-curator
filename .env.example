# =============================================================================
# AI Curator - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values as needed.
# All variables are optional - sensible defaults are provided.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3333)
AI_CURATOR_PORT=3333

# Server host (default: localhost)
AI_CURATOR_HOST=localhost

# Auto-open browser on start (default: true, set to false to disable)
AI_CURATOR_OPEN_BROWSER=true

# -----------------------------------------------------------------------------
# Data & Database
# -----------------------------------------------------------------------------

# Data directory for database (default: ~/.curator in user home directory)
# This ensures data is available regardless of where you run the command
# Set to ./data for project-scoped mode
AI_CURATOR_DATA_DIR=~/.curator

# Database file path (optional - only set if you need a custom location)
# If not set, defaults to <AI_CURATOR_DATA_DIR>/curator.db
# DATABASE_URL=~/.curator/curator.db

# -----------------------------------------------------------------------------
# External Integrations
# -----------------------------------------------------------------------------

# HuggingFace API token for downloading datasets
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# Your HuggingFace username (for linking to your profile)
HUGGINGFACE_USERNAME=your-username

# Kaggle credentials are read from ~/.kaggle/kaggle.json
# Run 'kaggle login' in your terminal to set up

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Application name (default: AI Curator)
NUXT_PUBLIC_APP_NAME=AI Curator

# Application version (default: 1.0.0)
NUXT_PUBLIC_APP_VERSION=1.0.0

# Node environment (development/production)
# Controls logging verbosity and dev features
NODE_ENV=development
